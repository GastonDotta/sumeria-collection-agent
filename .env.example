APP_NAME="Sumeria Collection Agent"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sumeria_collection
DB_USERNAME=root
DB_PASSWORD=

QUEUE_CONNECTION=sync
# Producción: QUEUE_CONNECTION=sqs
# SQS_KEY=
# SQS_SECRET=
# SQS_PREFIX=
# SQS_QUEUE=

# Llave interna compartida con el API gateway de Sumeria (para el webhook de detección de mora)
SUMERIA_SCORING_WEBHOOK_SECRET=

# Scoring API interno de Sumeria (Sprint 3+)
SUMERIA_SCORING_API_URL=https://api-interna.sumeria.io

# MercadoPago (Sprint 5+)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_API_URL=https://api.mercadopago.com

# WhatsApp Business API (Sprint 5+)
WA_API_URL=https://graph.facebook.com/v19.0
WA_API_TOKEN=
WA_PHONE_NUMBER_ID=

# API de Anthropic — Exception Agent LLM (Sprint 7+)
ANTHROPIC_API_KEY=

# Token de administración de Sumeria (para endpoints /admin)
# Generarlo con: php artisan tinker → $lender->createToken('sumeria-admin', ['sumeria-admin'])
SUMERIA_ADMIN_TOKEN=
